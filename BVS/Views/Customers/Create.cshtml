@model BVS.Models.Customer

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-sm me-3" style="background-color:#d9dcd6; color:#16425b;">
        <i class="fas fa-arrow-left"></i>
    </a>
    <h2 class="mb-0"><i class="fas fa-user-plus me-2" style="color:#3a7ca5;"></i>Add Customer</h2>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm" style="border-top: 4px solid #3a7ca5; border-radius: 12px;">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-semibold" style="color:#16425b;">
                            <i class="fas fa-user me-1" style="color:#3a7ca5;"></i> Full Name <span class="text-danger">*</span>
                        </label>
                        <input asp-for="FullName" class="form-control" placeholder="e.g. Juan Dela Cruz"
                               style="border-color:#d9dcd6;" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label fw-semibold" style="color:#16425b;">
                            <i class="fas fa-phone me-1" style="color:#3a7ca5;"></i> Phone
                        </label>
                        <input asp-for="Phone" class="form-control" placeholder="e.g. 09123456789"
                               style="border-color:#d9dcd6;" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold" style="color:#16425b;">
                            <i class="fas fa-envelope me-1" style="color:#3a7ca5;"></i> Email
                        </label>
                        <input asp-for="Email" class="form-control" placeholder="e.g. juan@email.com"
                               style="border-color:#d9dcd6;" />
                    </div>

                    <div class="mb-4">
                        <label asp-for="Address" class="form-label fw-semibold" style="color:#16425b;">
                            <i class="fas fa-location-dot me-1" style="color:#3a7ca5;"></i> Address
                        </label>
                        <textarea asp-for="Address" class="form-control" rows="3"
                                  placeholder="e.g. Buhangin, Davao City"
                                  style="border-color:#d9dcd6;"></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn text-white px-4"
                                style="background-color:#2f6690; border-color:#2f6690;">
                            <i class="fas fa-save me-1"></i> Save Customer
                        </button>
                        <a asp-action="Index" class="btn px-4"
                               style="background-color:#d9dcd6; color:#16425b;">
                            <i class="fas fa-xmark me-1"></i> Cancel
                        </a>
                    </div>

                </form>
            </div>
        </div>
    </div>

    <!-- Info Card -->
    <div class="col-md-4 offset-md-1">
        <div class="card shadow-sm h-auto" style="border-radius:12px; background-color:#f0f6fa; border:none;">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3" style="color:#16425b;">
                    <i class="fas fa-circle-info me-2" style="color:#81c3d7;"></i> Quick Tips
                </h6>
                <ul class="list-unstyled small" style="color:#2f6690;">
                    <li class="mb-2"><i class="fas fa-check me-2" style="color:#81c3d7;"></i> Full Name is required</li>
                    <li class="mb-2"><i class="fas fa-check me-2" style="color:#81c3d7;"></i> Phone and Email are optional</li>
                    <li class="mb-2"><i class="fas fa-check me-2" style="color:#81c3d7;"></i> Address helps with delivery tracking</li>
                    <li class="mb-2"><i class="fas fa-check me-2" style="color:#81c3d7;"></i> Customer can rent videos after being added</li>
                </ul>
            </div>
        </div>
    </div>
</div>