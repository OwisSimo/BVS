@model IEnumerable<BVS.Models.Customer>

<style>
    body {
        background-color: #d9dcd6;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .page-title {
        color: #16425b;
        font-weight: 600;
    }

    .btn-custom-primary {
        background-color: #2f6690;
        border: none;
        box-shadow: none;
        color: #fff;
        padding: 8px 16px;
        border-radius: 8px;
        transition: 0.3s;
    }

        .btn-custom-primary:focus {
            outline: none;
            box-shadow: none;
        }

        .btn-custom-primary:hover {
            background-color: #3a7ca5;
        }

    .card-container {
        background: #ffffff;
        padding: 20px;
        border-radius: 12px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
    }

    .table {
        border-radius: 10px;
        overflow: hidden;
    }

        .table thead {
            background-color: #16425b;
            color: #fff;
        }

        .table tbody tr {
            transition: 0.2s;
        }

            .table tbody tr:hover {
                background-color: #f1f6f9;
            }

    .btn-warning {
        background-color: #81c3d7;
        border: none;
        color: #16425b;
    }

        .btn-warning:hover {
            background-color: #3a7ca5;
            color: #fff;
        }

    .btn-danger {
        background-color: #d9534f;
        border: none;
    }

        .btn-danger:hover {
            background-color: #c9302c;
        }
</style>

<div class="page-header">
    <h2 class="page-title">Customers</h2>
    <a asp-action="Create" class="btn-custom-primary">+ Add Customer</a>
</div>

<div class="card-container">
    <table class="table table-bordered align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Phone</th>
                <th>Email</th>
                <th>Address</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td>@c.FullName</td>
                    <td>@c.Phone</td>
                    <td>@c.Email</td>
                    <td>@c.Address</td>
                    <td class="text-center">
                        <a asp-action="Edit" asp-route-id="@c.CustomerID"
                           class="btn btn-sm btn-warning me-1">Edit</a>

                        <a asp-action="Delete" asp-route-id="@c.CustomerID"
                           onclick="return confirm('Delete this customer?')"
                           class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>