@model IEnumerable<BVS.Models.Customer>
<h2>Customer Rental Report</h2>
<p class="text-muted">As of @DateTime.Today.ToString("MMMM dd, yyyy")</p>
@if (!Model.Any())
{
    <div class="alert alert-info">No active rentals at this time.</div>
}
@foreach (var c in Model)
{
    var activeRentals = c.Rentals.Where(r => !r.IsReturned).ToList();
    <div class="card mb-4">
        <div class="card-header">
            <strong>@c.FullName</strong>
            <span class="text-muted ms-2">@c.Phone</span>
            <span class="badge bg-primary ms-2">@activeRentals.Count active rental@(activeRentals.Count > 1 ? "s" : "")</span>
        </div>
        <div class="card-body p-0">
            <table class="table table-bordered mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Video</th>
                        <th>Category</th>
                        <th>Rent Date</th>
                        <th>Due Date</th>
                        <th>Status</th>
                        <th>Base Fee</th>
                        <th>Fine</th>
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in activeRentals)
                    {
                        var overdue = r.DueDate < DateTime.Today;
                        <tr class="@(overdue ? "table-danger" : "")">
                            <td>@r.Video?.Title</td>
                            <td><span class="badge @(r.Video?.Category == "DVD" ? "bg-success" : "bg-info")">@r.Video?.Category</span></td>
                            <td>@r.RentDate.ToString("MMM dd, yyyy")</td>
                            <td>@r.DueDate.ToString("MMM dd, yyyy")</td>
                            <td>@(overdue ? "Overdue" : "Active")</td>
                            <td>₱@r.BaseFee</td>
                            <td class="text-danger">@(r.OverdueFine > 0 ? "₱" + r.OverdueFine : "—")</td>
                            <td><strong>₱@r.TotalFee</strong></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
<a asp-action="VideoInventory" class="btn btn-secondary">← Video Inventory</a>